---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="ГАПТА — Студія машинної вишивки">
  <!-- ============ HERO ============ -->
  <section class="hero-section" data-screen-label="Hero" style="position:relative;background:var(--navy-900);color:var(--cream);overflow:hidden;">
    <div class="hero-bg" aria-hidden="true" style="position:absolute;top:0;bottom:0;left:0;right:360px;background-image:url('/assets/hero-shield.png');background-size:cover;background-position:left center;"></div>
    <div class="hero-bg-overlay" aria-hidden="true" style="position:absolute;inset:0;background:linear-gradient(90deg,rgba(11,19,38,0) 0%,rgba(11,19,38,0) 35%,rgba(11,19,38,0.55) 70%,rgba(11,19,38,0.85) 100%);"></div>

    <!-- NAV -->
    <div class="site-nav-wrap" style="background:var(--navy-900);">
      <header class="nav">
        <a class="brand" href="/">
          <div class="brand-name">ГАПТА</div>
          <div class="brand-divider"></div>
          <div class="brand-tag">Студія машинної<br>вишивки</div>
        </a>
        <ul class="nav-links">
          <li><a href="#services">Послуги</a></li>
          <li><a href="#portfolio">Портфоліо</a></li>
          <li><a href="#process">Процес</a></li>
          <li><a href="#materials">Матеріали</a></li>
          <li><a href="#about">Про нас</a></li>
          <li><a href="#contact">Контакти</a></li>
        </ul>
        <a class="nav-cta" href="#contact">Отримати розрахунок</a>
        <button class="nav-burger" id="nav-burger" aria-label="Меню" aria-expanded="false">
          <span></span>
        </button>
      </header>
      <nav class="mobile-menu" id="mobile-menu" aria-hidden="true">
        <ul>
          <li><a href="/">Головна</a></li>
          <li><a href="#services">Послуги</a></li>
          <li><a href="#portfolio">Портфоліо</a></li>
          <li><a href="#process">Процес</a></li>
          <li><a href="#materials">Матеріали</a></li>
          <li><a href="#about">Про нас</a></li>
          <li><a href="#contact">Контакти</a></li>
        </ul>
        <a class="nav-cta" href="#contact">Отримати розрахунок</a>
      </nav>
    </div>

    <div class="hero-grid" style="position:relative;z-index:4;display:grid;grid-template-columns:1fr 360px;">
      <div class="hero-center" style="grid-column:1;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:60px 56px 70px 50%;text-align:center;position:relative;">
        <div class="hero-eyebrow-row" style="display:flex;flex-direction:column;align-items:center;gap:14px;margin-bottom:28px;">
          <span class="eyebrow" style="color:var(--cream);font-weight:600;">Точна вишивка для сильних брендів</span>
          <div class="hero-divider" aria-hidden="true" style="display:flex;align-items:center;justify-content:center;gap:10px;width:220px;">
            <span style="flex:1;height:1px;background:var(--gold);opacity:0.7;"></span>
            <span style="width:8px;height:8px;background:var(--gold);transform:rotate(45deg);flex:0 0 auto;"></span>
            <span style="flex:1;height:1px;background:var(--gold);opacity:0.7;"></span>
          </div>
        </div>
        <h1 style="font-family:'Playfair Display',serif;font-weight:300;font-size:clamp(44px,4.6vw,70px);line-height:1.1;letter-spacing:-0.005em;color:var(--cream);max-width:520px;">
          Ідентичність<br>бренду, втілена<br>у <em style="font-style:italic;color:var(--gold-2);">тканині</em>
        </h1>
        <p style="margin-top:26px;font-size:14px;line-height:1.7;color:rgba(244,239,228,0.72);max-width:440px;">
          Створюємо шеврони, нашивки та вишивку<br>на одязі й аксесуарах з увагою до кожної деталі.
        </p>
        <div style="margin-top:38px;display:flex;gap:14px;flex-wrap:wrap;justify-content:center;">
          <a class="btn btn-primary" href="#contact">Замовити вишивку</a>
          <a class="btn btn-ghost" href="#portfolio">Переглянути роботи</a>
        </div>
        <img class="hero-seal-img" src="/assets/seal-gapta.png" alt="Печатка ГАПТА" style="position:absolute;left:5%;bottom:50px;width:110px;height:110px;">
      </div>

      <aside class="hero-rail" style="grid-column:2;position:relative;display:flex;flex-direction:column;z-index:5;">
        <div class="rail-card" style="background:rgba(10,16,32,0.92);color:var(--cream);padding:56px 40px 48px;border-left:1px solid var(--line);flex:0 0 auto;display:flex;flex-direction:column;">
          <span class="eyebrow" style="margin-bottom:22px;font-size:10px;color:var(--cream);opacity:0.85;">Преміальна вишивка</span>
          <h2 style="font-family:'Playfair Display',serif;font-weight:500;font-size:38px;line-height:1.25;color:var(--gold-2);">Для тих,<br>хто цінує<br>деталі</h2>
          <p style="margin-top:20px;font-size:13px;line-height:1.65;color:rgba(244,239,228,0.72);">Поєднання точності машини<br>та майстерності в кожному стібку.</p>
          <a href="#portfolio" style="margin-top:26px;color:var(--gold-2);font-size:10px;letter-spacing:0.24em;text-transform:uppercase;text-decoration:none;font-weight:600;display:inline-flex;align-items:center;gap:12px;">
            Дивитися портфоліо
            <span style="width:28px;height:1px;background:var(--gold-2);display:inline-block;"></span>
          </a>
        </div>
        <div aria-hidden="true" style="flex:0 0 auto;height:300px;min-height:300px;background-image:url('/assets/hero-machine.png');background-size:cover;background-position:center;border-left:1px solid var(--line);border-top:1px solid var(--line);position:relative;">
          <img src="/assets/seal-gapta.png" alt="Печатка ГАПТА" style="position:absolute;left:24px;bottom:24px;width:86px;height:86px;">
        </div>
      </aside>
    </div>

    <style>
      @media (max-width: 1100px) {
        .hero-section .hero-bg { right: 0 !important; }
        .hero-grid { grid-template-columns: 1fr !important; }
        .hero-center { padding: 80px 36px 60px !important; min-height: 560px; align-items: center !important; padding-left: 36px !important; }
        .hero-seal-img { left: 24px !important; bottom: 24px !important; width: 90px !important; height: 90px !important; }
        .hero-rail { grid-column: 1 !important; flex-direction: row !important; }
        .hero-rail .rail-card { padding: 34px 36px !important; border-left: none !important; border-top: 1px solid var(--line) !important; flex: 1 !important; }
        .hero-rail > div:last-child { width: 320px !important; height: auto !important; min-height: 260px !important; border-left: 1px solid var(--line) !important; border-top: 1px solid var(--line) !important; }
      }
      @media (max-width: 640px) {
        .hero-center { padding: 40px 22px 50px !important; min-height: 500px !important; }
        .hero-seal-img { display: none !important; }
        .hero-rail { flex-direction: column !important; }
        .hero-rail .rail-card { padding: 28px 22px !important; }
        .hero-rail .rail-card h2 { font-size: 30px !important; }
        .hero-rail > div:last-child { width: 100% !important; height: 200px !important; min-height: 200px !important; border-left: none !important; }
      }
    </style>
  </section>

  <!-- ============ SERVICES ============ -->
  <section class="services" id="services" data-screen-label="Services" style="background:var(--cream);padding:20px 56px;border-bottom:1px solid var(--line-cream);">
    <div class="services-inner" style="display:grid;grid-template-columns:180px 1fr;gap:25px;align-items:center;">
      <div class="services-head" style="display:flex;flex-direction:column;align-items:flex-start;gap:14px;">
        <h2 style="font-family:'Playfair Display',serif;font-weight:400;font-size:30px;line-height:1.05;color:var(--navy-900);text-transform:uppercase;letter-spacing:0.12em;">НАШІ<br>ПОСЛУГИ</h2>
        <div class="title-divider" aria-hidden="true">
          <span class="seg"></span>
          <span class="diamond"></span>
        </div>
      </div>
      <div style="display:grid;grid-template-columns:repeat(6,1fr);gap:16px;">
        <div style="display:flex;align-items:center;gap:12px;padding:4px 0;"><svg style="width:38px;height:38px;flex-shrink:0;color:var(--navy-900);" viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="1.2"><path d="M20 5l13 5v10c0 8-6 13-13 15-7-2-13-7-13-15V10z"/></svg><div style="font-size:12px;line-height:1.35;color:var(--navy-900);font-weight:500;">Шеврони<br>та нашивки</div></div>
        <div style="display:flex;align-items:center;gap:12px;padding:4px 0 4px 20px;position:relative;"><span style="position:absolute;left:0;top:50%;transform:translateY(-50%);width:1px;height:32px;background:var(--gold);"></span><svg style="width:38px;height:38px;flex-shrink:0;color:var(--navy-900);" viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="1.2"><path d="M14 7l-9 4 3 7 4-1v17h16V17l4 1 3-7-9-4-3 3a4 4 0 01-6 0z"/></svg><div style="font-size:12px;line-height:1.35;color:var(--navy-900);font-weight:500;">Вишивка<br>на одязі</div></div>
        <div style="display:flex;align-items:center;gap:12px;padding:4px 0 4px 20px;position:relative;"><span style="position:absolute;left:0;top:50%;transform:translateY(-50%);width:1px;height:32px;background:var(--gold);"></span><svg style="width:38px;height:38px;flex-shrink:0;color:var(--navy-900);" viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="1.2"><g transform="translate(20 20)"><ellipse cx="0" cy="-9" rx="3.2" ry="7"/><ellipse cx="0" cy="9" rx="3.2" ry="7"/><ellipse cx="-9" cy="0" rx="7" ry="3.2"/><ellipse cx="9" cy="0" rx="7" ry="3.2"/><ellipse cx="-6.4" cy="-6.4" rx="3.2" ry="7" transform="rotate(-45)"/><ellipse cx="6.4" cy="6.4" rx="3.2" ry="7" transform="rotate(-45)"/><ellipse cx="-6.4" cy="6.4" rx="3.2" ry="7" transform="rotate(45)"/><ellipse cx="6.4" cy="-6.4" rx="3.2" ry="7" transform="rotate(45)"/><circle cx="0" cy="0" r="2.2"/></g></svg><div style="font-size:12px;line-height:1.35;color:var(--navy-900);font-weight:500;">Фірмова<br>вишивка</div></div>
        <div style="display:flex;align-items:center;gap:12px;padding:4px 0 4px 20px;position:relative;"><span style="position:absolute;left:0;top:50%;transform:translateY(-50%);width:1px;height:32px;background:var(--gold);"></span><svg style="width:38px;height:38px;flex-shrink:0;color:var(--navy-900);" viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="1.2"><path d="M14 6l-7 4 2 8 4-1v17h14V17l4 1 2-8-7-4M14 6l3 3a4 4 0 006 0l3-3M14 6h12M20 13v22"/></svg><div style="font-size:12px;line-height:1.35;color:var(--navy-900);font-weight:500;">Брендована<br>уніформа</div></div>
        <div style="display:flex;align-items:center;gap:12px;padding:4px 0 4px 20px;position:relative;"><span style="position:absolute;left:0;top:50%;transform:translateY(-50%);width:1px;height:32px;background:var(--gold);"></span><svg style="width:38px;height:38px;flex-shrink:0;color:var(--navy-900);" viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="1.2"><rect x="5" y="8" width="30" height="20" rx="1"/><path d="M14 32h12M16 28v4M24 28v4"/><circle cx="20" cy="18" r="3"/></svg><div style="font-size:12px;line-height:1.35;color:var(--navy-900);font-weight:500;">Диджиталізація<br>та розробка</div></div>
        <div style="display:flex;align-items:center;gap:12px;padding:4px 0 4px 20px;position:relative;"><span style="position:absolute;left:0;top:50%;transform:translateY(-50%);width:1px;height:32px;background:var(--gold);"></span><svg style="width:38px;height:38px;flex-shrink:0;color:var(--navy-900);" viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="1.2"><path d="M20 5l13 6v18l-13 6-13-6V11z"/><path d="M7 11l13 6 13-6M20 17v18"/></svg><div style="font-size:12px;line-height:1.35;color:var(--navy-900);font-weight:500;">Оптове<br>виробництво</div></div>
      </div>
      <div style="grid-column:1/-1;margin-top:1px;display:flex;justify-content:space-between;align-items:center;gap:24px;">
        <div aria-hidden="true" style="display:flex;align-items:center;gap:10px;">
          <span style="width:7px;height:7px;background:var(--gold);transform:rotate(45deg);flex-shrink:0;display:inline-block;"></span>
          <span style="width:60px;height:1px;background:var(--gold);opacity:0.6;display:inline-block;"></span>
        </div>
        <a href="#contact" style="color:var(--navy-900);font-size:11px;letter-spacing:0.24em;text-transform:uppercase;text-decoration:none;font-weight:600;display:inline-flex;align-items:center;gap:12px;">Усі послуги →</a>
      </div>
    </div>
    <style>
      @media (max-width: 1100px) {
        #services { padding: 60px 36px !important; }
        #services .services-inner { grid-template-columns: 1fr !important; gap: 36px !important; }
        #services .services-inner > div:nth-child(2) { grid-template-columns: repeat(3,1fr) !important; gap: 24px !important; }
      }
      @media (max-width: 640px) {
        #services { padding: 44px 22px !important; }
        #services .services-inner > div:nth-child(2) { grid-template-columns: repeat(2,1fr) !important; gap: 22px !important; }
      }
    </style>
  </section>

  <!-- ============ PROCESS ============ -->
  <section class="process" id="process" data-screen-label="Process" style="background:var(--navy-900);color:var(--cream);padding:15px 56px;position:relative;overflow:hidden;">
    <div aria-hidden="true" style="position:absolute;right:0;top:0;bottom:0;width:50%;background:url('/assets/process-floral.png') no-repeat right bottom / auto 100%;opacity:0.85;pointer-events:none;z-index:0;"></div>
    <div style="position:relative;z-index:1;display:grid;grid-template-columns:280px 1fr;gap:80px;align-items:start;">
      <div>
        <span class="eyebrow" style="color:var(--gold);opacity:1;">Процес</span>
        <h2 style="font-family:'Playfair Display',serif;font-weight:200;font-size:32px;line-height:1.1;color:var(--gold-2);margin-top:5px;">Майстерність<br>у кожному етапі</h2>
        <p style="margin-top:10px;font-size:13px;line-height:1.7;color:rgba(244,239,228,0.72);">Від ідеї до готового виробу —<br>контроль якості на кожному кроці.</p>
        <a href="#contact" style="margin-top:10px;display:inline-flex;align-items:center;gap:14px;color:var(--gold-2);font-size:10px;letter-spacing:0.26em;text-transform:uppercase;text-decoration:none;font-weight:600;">Дивитися як ми працюємо →</a>
      </div>
      <div style="display:grid;grid-template-columns:repeat(4,minmax(0,220px));gap:4px;align-content:start;padding-top:4px;">
        <div style="position:relative;padding-left:38px;">
          <span style="position:absolute;left:0;top:4px;bottom:4px;width:1px;background:var(--gold-2);opacity:1;"></span>
          <div style="font-family:'Playfair Display',serif;font-size:55px;color:var(--gold);line-height:1;font-weight:200;opacity:0.35;">01</div>
          <h3 style="margin-top:8px;font-family:'Playfair Display',serif;font-weight:100;font-size:16px;color:var(--cream);letter-spacing:0.01em;">Дизайн</h3>
          <p style="margin-top:8px;font-size:12px;line-height:1.65;color:rgba(244,239,228,0.65);">Розробляємо макет<br>та підбираємо рішення</p>
        </div>
        <div style="position:relative;padding-left:38px;">
          <span style="position:absolute;left:0;top:4px;bottom:4px;width:1px;background:var(--gold);opacity:0.35;"></span>
          <div style="font-family:'Playfair Display',serif;font-size:55px;color:var(--gold);line-height:1;font-weight:200;opacity:0.35;">02</div>
          <h3 style="margin-top:8px;font-family:'Playfair Display',serif;font-weight:100;font-size:16px;color:var(--cream);letter-spacing:0.01em;">Диджиталізація</h3>
          <p style="margin-top:8px;font-size:12px;line-height:1.65;color:rgba(244,239,228,0.65);">Точна програма<br>для бездоганного<br>результату</p>
        </div>
        <div style="position:relative;padding-left:38px;">
          <span style="position:absolute;left:0;top:4px;bottom:4px;width:1px;background:var(--gold);opacity:0.35;"></span>
          <div style="font-family:'Playfair Display',serif;font-size:55px;color:var(--gold);line-height:1;font-weight:200;opacity:0.35;">03</div>
          <h3 style="margin-top:8px;font-family:'Playfair Display',serif;font-weight:100;font-size:16px;color:var(--cream);letter-spacing:0.01em;">Вишивка</h3>
          <p style="margin-top:8px;font-size:12px;line-height:1.65;color:rgba(244,239,228,0.65);">Сучасне обладнання<br>та якісні матеріали</p>
        </div>
        <div style="position:relative;padding-left:38px;">
          <span style="position:absolute;left:0;top:4px;bottom:4px;width:1px;background:var(--gold);opacity:0.35;"></span>
          <div style="font-family:'Playfair Display',serif;font-size:55px;color:var(--gold);line-height:1;font-weight:200;opacity:0.35;">04</div>
          <h3 style="margin-top:8px;font-family:'Playfair Display',serif;font-weight:100;font-size:16px;color:var(--cream);letter-spacing:0.01em;">Контроль якості</h3>
          <p style="margin-top:8px;font-size:12px;line-height:1.65;color:rgba(244,239,228,0.65);">Перевірка кожної деталі<br>перед відправкою</p>
        </div>
      </div>
    </div>
    <style>
      @media (max-width: 1100px) {
        #process { padding: 70px 36px !important; }
        #process > div { grid-template-columns: 1fr !important; gap: 40px !important; }
        #process > div > div:last-child { grid-template-columns: repeat(2,1fr) !important; gap: 32px !important; }
      }
      @media (max-width: 640px) {
        #process { padding: 50px 22px !important; }
        #process > div > div:first-child h2 { font-size: 30px !important; }
        #process > div > div:last-child { grid-template-columns: 1fr !important; gap: 28px !important; }
      }
    </style>
  </section>

  <!-- ============ MATERIALS ============ -->
  <section class="materials" id="materials" data-screen-label="Materials" style="background:var(--cream-2);padding:10px 60px;">
    <div style="display:grid;grid-template-columns:300px 1fr;gap:60px;align-items:center;">
      <div>
        <span class="eyebrow" style="color:var(--navy-900);opacity:0.85;">Матеріали</span>
        <h2 style="font-family:'Playfair Display',serif;font-weight:200;font-size:30px;line-height:1.1;color:var(--navy-900);margin-top:20px;">Преміальні тканини<br>та нитки</h2>
        <p style="margin-top:10px;font-size:13px;line-height:1.7;color:rgba(20,28,50,0.7);">Працюємо з перевіреними матеріалами,<br>що забезпечують довговічність, насиченість<br>кольору та бездоганний вигляд.</p>
        <a href="#contact" style="margin-top:20px;display:inline-flex;align-items:center;gap:14px;color:var(--navy-900);font-size:13px;letter-spacing:0.26em;text-transform:uppercase;text-decoration:none;font-weight:600;">Переглянути матеріали →</a>
      </div>
      <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:12px;position:relative;">
        <div style="aspect-ratio:4/4;background:url('/assets/mat-1.png') center/cover no-repeat;background-color:var(--navy-800);"></div>
        <div style="aspect-ratio:4/4;background:url('/assets/mat-2.png') center/cover no-repeat;background-color:var(--navy-800);"></div>
        <div style="aspect-ratio:4/4;background:url('/assets/mat-3.png') center/cover no-repeat;background-color:var(--navy-800);"></div>
        <div style="aspect-ratio:4/4;background:url('/assets/mat-4.png') center/cover no-repeat;background-color:var(--navy-800);"></div>
        <div style="position:absolute;right:-64px;bottom:16px;background:var(--navy-900);color:var(--gold-2);border:1px solid var(--gold-2);padding:18px 22px;font-size:10px;letter-spacing:0.22em;text-transform:uppercase;line-height:1.7;font-weight:500;z-index:20;">
          Якість у деталях<br>вишивка, що говорить<br>про ваш бренд
        </div>
      </div>
    </div>
    <style>
      @media (max-width: 1100px) {
        #materials { padding: 60px 36px !important; }
        #materials > div { grid-template-columns: 1fr !important; gap: 36px !important; }
        #materials > div > div:last-child { grid-template-columns: repeat(4,1fr) !important; }
        #materials > div > div:last-child > div:last-child { right: 0 !important; }
      }
      @media (max-width: 640px) {
        #materials { padding: 50px 22px !important; }
        #materials > div > div:first-child h2 { font-size: 28px !important; }
        #materials > div > div:last-child { grid-template-columns: repeat(2,1fr) !important; }
        #materials > div > div:last-child > div:last-child { right: 0 !important; bottom: 8px !important; padding: 12px 14px !important; font-size: 9px !important; }
      }
    </style>
  </section>

  <!-- ============ PORTFOLIO ============ -->
  <section class="portfolio" id="portfolio" data-screen-label="Portfolio" style="background:var(--navy-900);padding:25px 56px;position:relative;">
    <div style="display:grid;grid-template-columns:300px 1fr;gap:56px;align-items:center;">
      <div>
        <span class="eyebrow" style="color:var(--gold-2);">Портфоліо</span>
